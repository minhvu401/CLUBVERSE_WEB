# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ===========================
# Node / Yarn / PNPM
# ===========================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===========================
# Next.js
# ===========================
.next/
out/
build/

# ===========================
# TypeScript
# ===========================
*.tsbuildinfo
next-env.d.ts

# ===========================
# Environment
# ===========================
.env*
*.pem

# ===========================
# macOS
# ===========================
.DS_Store

# ===========================
# IntelliJ / WebStorm / JetBrains IDE
# ===========================
.idea/
*.iml
out/

# JetBrains user-specific files
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf

# Allow these (optional)
#!.idea/codeStyles
#!.idea/runConfigurations

